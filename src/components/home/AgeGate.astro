<div class="age-gate" id="ageGate" role="dialog" aria-modal="true" aria-labelledby="ageTitle">
  <div class="age-card">
    <div class="age-badge">18+</div>
    <h2 id="ageTitle">Adult confirmation</h2>
    <p>This site is intended for adults only. Confirm you are of legal age in your location to continue.</p>
    <div class="age-actions">
      <button class="button" id="enterSite" type="button">I am of legal age</button>
      <button class="button secondary" id="leaveSite" type="button">Not today</button>
    </div>
  </div>
</div>
