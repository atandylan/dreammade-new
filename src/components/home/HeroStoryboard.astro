---
import { site } from "../../data/site";
---

<section class="hero" aria-label="Dreammade hero">
  <div class="hero-grain" aria-hidden="true"></div>
  <div class="hero-ghost" aria-hidden="true">DREAMMADE</div>
  <div class="wrap hero-inner">
    <div class="hero-copy">
      <h1 class="hero-title" aria-label={site.name}>
        <span class="title-line title-line-one"><span>{site.name.slice(0, 5)}</span></span>
        <span class="title-line title-line-two"><span>{site.name.slice(5)}</span></span>
      </h1>
      <p class="hero-line" data-reveal>{site.description}</p>
      <div class="hero-actions hero-line" data-reveal>
        <a class="button" href="#products">Explore Syok</a>
        <a class="button secondary" href="#about">Brand story</a>
      </div>
      <p class="hero-tagline hero-line" data-reveal>{site.tagline}</p>
    </div>
    
    <div class="hero-devices-float hero-line">
      <div class="hero-device" data-device="1" style="--rot: -8deg; --x: 0%; --y: 0%; --delay: 0s">
        <img src="/products/syokpod/v2/syokpod-v2-black-01.webp" alt="Syokpod V2 Black" width="180" height="320" loading="eager">
      </div>
      <div class="hero-device" data-device="2" style="--rot: 4deg; --x: 40%; --y: 10%; --delay: 0.15s">
        <img src="/products/syokpod/v2/syokpod-v2-red-01.webp" alt="Syokpod V2 Red" width="180" height="320" loading="eager">
      </div>
      <div class="hero-device" data-device="3" style="--rot: -3deg; --x: 75%; --y: -5%; --delay: 0.3s">
        <img src="/products/syokbar/SYOKBAR/syokbar-grey-01.webp" alt="Syokbar Grey" width="220" height="260" loading="eager">
      </div>
      <div class="hero-device" data-device="4" style="--rot: 6deg; --x: 110%; --y: 8%; --delay: 0.45s">
        <img src="/products/syokbar/SYOKBAR/syokbar-orange-01.webp" alt="Syokbar Orange" width="220" height="260" loading="eager">
      </div>
    </div>

    <div class="hero-index" aria-hidden="true">
      <span>Dreammade</span>
      <span>Est. Malaysia</span>
    </div>
  </div>
</section>
