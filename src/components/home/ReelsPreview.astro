---
// No server-side fetch — all client-side
---

<section class="feed-section" id="feed">
  <div class="wrap">
    <div class="eyebrow" data-reveal>From the feed</div>
    <h2 class="section-title">
      <span class="reveal-line" data-reveal-clip><span>From the</span></span>
      <span class="reveal-line" data-reveal-clip><span>'Gram.</span></span>
    </h2>
  </div>
  <div class="feed-track-container">
    <div class="feed-track" id="feedTrack" aria-label="Dreammade Instagram photos">
      <!-- JS will inject cards here -->
    </div>
  </div>
</section>

<script>
  async function loadIGPhotos() {
    const track = document.getElementById("feedTrack");
    if (!track) return;

    try {
      const res = await fetch("https://dreammade-ig-reels.fadzry-work.workers.dev/");
      if (!res.ok) throw new Error("fetch failed");
      const json = await res.json();

      const photos = Array.isArray(json.photos) ? json.photos : [];
      if (!photos.length) return;

      const makeCard = (photo: any, hidden = false) => {
        const article = document.createElement("article");
        article.className = "reel-card";
        if (hidden) {
          article.setAttribute("aria-hidden", "true");
        }
        const captionLine = photo.caption ? photo.caption.split("\n")[0] : "Dreammade";
        const href = photo.permalink || "https://www.instagram.com/syok_geng/";
        article.innerHTML = `
          <a href="${href}" target="_blank" rel="noopener noreferrer" class="reel-link"
             ${hidden ? 'tabindex="-1"' : ''} aria-label="${captionLine}">
            <div class="reel-video-wrapper">
              <img class="reel-image" src="${photo.media_url}"
                   alt="${captionLine}" loading="lazy" decoding="async" />
              <div class="image-overlay"></div>
            </div>
            <div class="reel-label">${captionLine}</div>
          </a>
        `;
        return article;
      };

      // Original set + duplicate for infinite scroll
      const frag = document.createDocumentFragment();
      photos.forEach((p: any) => frag.appendChild(makeCard(p, false)));
      photos.forEach((p: any) => frag.appendChild(makeCard(p, true)));
      track.appendChild(frag);

      // Trigger GSAP marquee after cards are in DOM
      if (typeof window !== "undefined" && (window as any).__startFeedMarquee) {
        (window as any).__startFeedMarquee();
      }

    } catch (e) {
      console.error("IG photos load failed:", e);
    }
  }

  document.addEventListener("DOMContentLoaded", loadIGPhotos);
  document.addEventListener("astro:page-load", loadIGPhotos);
</script>
