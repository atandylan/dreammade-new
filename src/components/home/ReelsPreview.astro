---
interface MediaItem {
  id: string;
  caption?: string;
  media_type?: string;
  media_url?: string;
  permalink?: string;
  thumbnail_url?: string;
}

let photosData: MediaItem[] = [];

try {
  const response = await fetch("https://dreammade-ig-reels.fadzry-work.workers.dev/");
  if (response.ok) {
    const json = await response.json();
    const all: MediaItem[] = Array.isArray(json.photos) ? json.photos
      : Array.isArray(json.reels) ? json.reels : [];
    // Images only — filter out VIDEO
    photosData = all.filter(
      (item) => item.media_type !== "VIDEO" && !item.media_url?.includes(".mp4")
    );
  }
} catch (e) {
  console.error("Failed to fetch IG photos:", e);
}
---

<section class="feed-section" id="feed">
  <div class="wrap">
    <div class="eyebrow" data-reveal>From the feed</div>
    <h2 class="section-title">
      <span class="reveal-line" data-reveal-clip><span>From the</span></span>
      <span class="reveal-line" data-reveal-clip><span>'Gram.</span></span>
    </h2>
  </div>
  <div class="feed-track-container">
    <div class="feed-track" id="feedTrack" aria-label="Dreammade Instagram photos">
      {photosData.map((photo) => (
        <article class="reel-card">
          <a href={photo.permalink || "https://www.instagram.com/syok_geng/"} target="_blank" rel="noopener noreferrer" class="reel-link" aria-label={photo.caption || "Instagram photo"}>
            <div class="reel-video-wrapper">
              <img
                class="reel-image"
                src={photo.media_url}
                alt={photo.caption?.split('\n')[0] || "Dreammade"}
                loading="lazy"
                decoding="async"
              />
              <div class="image-overlay"></div>
            </div>
            {photo.caption && (
              <div class="reel-label">{photo.caption.split('\n')[0]}</div>
            )}
          </a>
        </article>
      ))}
      {/* Duplicate for infinite scroll */}
      {photosData.map((photo) => (
        <article class="reel-card" aria-hidden="true">
          <a href={photo.permalink || "https://www.instagram.com/syok_geng/"} target="_blank" rel="noopener noreferrer" class="reel-link" tabindex="-1">
            <div class="reel-video-wrapper">
              <img
                class="reel-image"
                src={photo.media_url}
                alt={photo.caption?.split('\n')[0] || "Dreammade"}
                loading="lazy"
                decoding="async"
              />
              <div class="image-overlay"></div>
            </div>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
