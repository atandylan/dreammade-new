---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden w-full hero-section">
  <div class="absolute inset-0 z-[-1] hero-bg-gradient"></div>
  
  <!-- Massive 'S' logo centered in the absolute background of the entire section -->
  <img src="/intro-logo.svg" class="absolute inset-0 m-auto w-[90%] h-[90%] object-contain opacity-10 pointer-events-none z-0" style="mix-blend-mode: overlay;" />
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center min-h-screen px-8 w-full max-w-7xl mx-auto hero-container">
    {/* Left Column */}
    <div class="hero-left-column flex flex-col justify-center">
      <h1 class="hero-title hero-line text-5xl md:text-7xl font-extrabold uppercase leading-[0.85] text-[#F5F5DC] mb-4">
        BUILT DIFFERENT.
      </h1>
      <p class="hero-desc hero-line text-lg text-[#F5F5DC] mb-8 max-w-md leading-snug opacity-80">
        Designed around the ease of closed systems and bold flavours. The SyokGeng identity meets raw performance.
      </p>
      <a href="#products" class="hero-btn hero-line button w-fit">
        Explore the Gear
      </a>
    </div>

    {/* Right Column: Clean horizontal row */}
    <div class="hero-right-column hero-devices-row relative w-full flex items-center justify-center overflow-visible">
      <img 
      	src="/products/syokpod/v2/syokpod-v2-red-01.webp" 
      	alt="Syokpod V2 Red" 
      	class="hero-device device-1"
      	loading="eager"
      />
      <img 
      	src="/products/syokpod/pro/syokpod-pro-gold-01.webp" 
      	alt="Syokpod Pro Gold" 
      	class="hero-device device-2"
      	loading="eager"
      />
      <img 
      	src="/products/syokbar/SYOKBAR/syokbar-grey-01.webp" 
      	alt="Syokbar Grey" 
      	class="hero-device device-3"
      	loading="eager"
      />
      <img 
      	src="/products/syokbar/SYOKBAR TARGET/syokbar-target-orange-01.webp" 
      	alt="Syokbar Target Orange" 
      	class="hero-device device-4"
      	loading="eager"
      />
    </div>
  </div>
</section>

<style>
  .hero-bg-gradient {
    background: radial-gradient(circle at 75% 45%, #91050b 0%, #030303 85%) !important;
  }
  .hero-section {
    position: relative;
    background: radial-gradient(circle at 75% 45%, #91050b 0%, #030303 85%) !important;
  }
  .bg-\[\#91050b\] {
    background-color: #91050b;
  }
  .text-\[\#F5F5DC\] {
    color: #F5F5DC !important;
  }
  .absolute {
    position: absolute;
  }
  .inset-0 {
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
  }
  .m-auto {
    margin: auto !important;
  }
  .w-\[90\%\] {
    width: 90% !important;
  }
  .h-\[90\%\] {
    height: 90% !important;
  }
  .opacity-10 {
    opacity: 0.1 !important;
  }
  .z-0 {
    z-index: 0;
  }
  .pointer-events-none {
    pointer-events: none;
  }
  .object-contain {
    object-fit: contain;
  }
  .w-full {
    width: 100%;
  }
  .overflow-hidden {
    overflow: hidden;
  }
  
  /* Compact 2-column layout */
  .hero-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
    min-height: 100vh;
    padding-left: 2rem;
    padding-right: 2rem;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 10;
  }

  @media (min-width: 768px) {
    .hero-container {
      grid-template-columns: 1.1fr 0.9fr;
      gap: 3rem;
    }
  }

  .hero-left-column {
    display: flex;
    flex-direction: column;
    justify-content: center;
    color: #F5F5DC;
    z-index: 5;
  }

  .hero-title {
    font-family: var(--font-display, 'Archivo Black', 'Inter', sans-serif);
    font-size: clamp(48px, 6.2vw, 88px); /* scaled down proportionately */
    font-weight: 900;
    line-height: 0.85 !important;
    letter-spacing: -0.04em;
    margin: 0 0 1rem;
    text-transform: uppercase;
  }

  .hero-desc {
    font-size: clamp(15px, 1.1vw, 18px);
    color: rgba(245, 245, 220, 0.8);
    line-height: 1.35 !important;
    margin-bottom: 2rem;
    max-width: 480px;
  }

  .hero-btn {
    display: inline-block;
    padding: 16px 36px;
    border-radius: 9999px;
    font-size: 14px;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.3s, transform 0.3s;
    background: #F5F5DC;
    color: #91050b;
    border: 1px solid #F5F5DC;
    width: fit-content;
  }

  .hero-btn:hover {
    transform: translateY(-2px);
    background: transparent;
    color: #F5F5DC;
  }

  .hero-right-column {
    position: relative;
    height: 500px;
    width: 100%;
    z-index: 5;
  }

  /* Absolute Overlapping Stacking Layout */
  .hero-devices-row {
    position: relative !important;
    display: block !important;
    width: 100% !important;
    height: 500px !important;
  }

  .hero-device {
    position: absolute !important;
    bottom: 10px !important;
    width: 28% !important;
    height: clamp(380px, 45vh, 480px) !important;
    object-fit: contain !important;
    filter: drop-shadow(0 15px 30px rgba(0, 0, 0, 0.5)) !important;
    transform-origin: bottom center !important;
    transition: transform 0.4s ease !important;
  }

  /* Absolute position and custom scaling to match visual sizes */
  .device-1 {
    left: 6% !important;
    z-index: 10 !important;
    transform: rotate(-10deg) translateY(15px) scale(0.92) !important;
  }
  .device-2 {
    left: 28% !important;
    z-index: 20 !important;
    transform: rotate(-3deg) translateY(-10px) scale(1.06) !important;
  }
  .device-3 {
    left: 50% !important;
    z-index: 30 !important;
    transform: rotate(4deg) translateY(5px) scale(0.98) !important;
  }
  .device-4 {
    left: 72% !important;
    z-index: 40 !important;
    transform: rotate(10deg) translateY(20px) scale(1.02) !important;
  }

  @media (max-width: 768px) {
    .hero-devices-row {
      height: 320px !important;
    }
    .hero-device {
      width: 26% !important;
      height: clamp(240px, 35vh, 290px) !important;
    }
    .device-1 {
      left: 4% !important;
      transform: rotate(-10deg) translateY(10px) scale(0.92) !important;
    }
    .device-2 {
      left: 26% !important;
      transform: rotate(-3deg) translateY(-5px) scale(1.06) !important;
    }
    .device-3 {
      left: 48% !important;
      transform: rotate(4deg) translateY(2px) scale(0.98) !important;
    }
    .device-4 {
      left: 70% !important;
      transform: rotate(10deg) translateY(12px) scale(1.02) !important;
    }
  }
</style>
