---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden w-full hero-section">
  <div class="absolute inset-0 z-0 hero-bg-image"></div>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center min-h-screen px-8 w-full max-w-7xl mx-auto hero-container">
    {/* Left Column */}
    <div class="hero-left-column flex flex-col justify-center">
      <h1 class="hero-title hero-line text-5xl md:text-7xl font-extrabold uppercase leading-[0.85] text-[#F5F5DC] mb-4">
        BUILT DIFFERENT.
      </h1>
      <p class="hero-desc hero-line text-lg text-[#F5F5DC] mb-8 max-w-md leading-snug opacity-80">
        Designed around the ease of closed systems and bold flavours. The SyokGeng identity meets raw performance.
      </p>
      <a href="#products" class="hero-btn hero-line button w-fit">
        Explore the Gear
      </a>
    </div>

    {/* Right Column: Mobile-only fanned devices markup, empty on desktop */}
    <div class="hero-right-column hero-devices-row relative w-full flex items-center justify-center overflow-visible">
      <img src="/products/syokpod/v2/syokpod-v2-red-01.webp" class="hero-mobile-device mdevice-1" alt="SyokPod V2 Red" />
      <img src="/products/syokpod/pro/syokpod-pro-obsidian-01.webp" class="hero-mobile-device mdevice-2" alt="SyokPod Pro Obsidian" />
      <img src="/products/syokbar/SYOKBAR/syokbar-red-01.webp" class="hero-mobile-device mdevice-3" alt="SyokBar Red" />
      <img src="/products/syokbar/SYOKBAR TARGET/syokbar-target-orange-01.webp" class="hero-mobile-device mdevice-4" alt="SyokBar Target Orange" />
    </div>
  </div>
</section>

<style>
  .hero-bg-image {
    background-image: url('/website-hero.jpg');
    background-size: cover;
    background-position: 80% center;
    background-repeat: no-repeat;
  }
  @media (max-width: 768px) {
    .hero-bg-image {
      background-image:
        url("data:image/svg+xml,%3Csvg viewBox='0 0 250 250' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='roughNoiseRed'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.58' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23roughNoiseRed)' opacity='0.10'/%3E%3C/svg%3E"),
        radial-gradient(circle at 50% 50%, #91050b 0%, #4d0407 100%) !important;
      background-size: auto, cover !important;
      background-position: center !important;
    }
  }
  .hero-section {
    position: relative;
    background: #030303 !important;
  }
  .bg-\[\#91050b\] {
    background-color: #91050b;
  }
  .text-\[\#F5F5DC\] {
    color: #F5F5DC !important;
  }
  .absolute {
    position: absolute;
  }
  .inset-0 {
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
  }
  .m-auto {
    margin: auto !important;
  }
  .w-\[90\%\] {
    width: 90% !important;
  }
  .h-\[90\%\] {
    height: 90% !important;
  }
  .opacity-10 {
    opacity: 0.1 !important;
  }
  .z-0 {
    z-index: 0;
  }
  .pointer-events-none {
    pointer-events: none;
  }
  .object-contain {
    object-fit: contain;
  }
  .w-full {
    width: 100%;
  }
  .overflow-hidden {
    overflow: hidden;
  }
  
  /* Compact 2-column layout */
  .hero-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
    min-height: 100vh;
    padding-left: 2rem;
    padding-right: 2rem;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 10;
  }

  @media (min-width: 768px) {
    .hero-container {
      grid-template-columns: 1.1fr 0.9fr;
      gap: 3rem;
    }
  }

  .hero-left-column {
    display: flex;
    flex-direction: column;
    justify-content: center;
    color: #F5F5DC;
    z-index: 5;
  }

  .hero-title {
    font-family: var(--font-display, 'Archivo Black', 'Inter', sans-serif);
    font-size: clamp(48px, 6.2vw, 88px); /* scaled down proportionately */
    font-weight: 900;
    line-height: 0.85 !important;
    letter-spacing: -0.04em;
    margin: 0 0 1rem;
    text-transform: uppercase;
  }

  .hero-desc {
    font-size: clamp(15px, 1.1vw, 18px);
    color: rgba(245, 245, 220, 0.8);
    line-height: 1.35 !important;
    margin-bottom: 2rem;
    max-width: 480px;
  }

  .hero-btn {
    display: inline-block;
    padding: 16px 36px;
    border-radius: 9999px;
    font-size: 14px;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.3s, transform 0.3s;
    background: #F5F5DC;
    color: #91050b;
    border: 1px solid #F5F5DC;
    width: fit-content;
  }

  .hero-btn:hover {
    transform: translateY(-2px);
    background: transparent;
    color: #F5F5DC;
  }

  .hero-right-column {
    position: relative;
    height: 500px;
    width: 100%;
    z-index: 5;
  }

  /* Absolute Overlapping Stacking Layout */
  .hero-devices-row {
    position: relative !important;
    display: block !important;
    width: 100% !important;
    height: 500px !important;
  }

  .hero-device {
    position: absolute !important;
    bottom: 10px !important;
    width: 28% !important;
    height: clamp(380px, 45vh, 480px) !important;
    object-fit: contain !important;
    filter: drop-shadow(0 15px 30px rgba(0, 0, 0, 0.5)) !important;
    transform-origin: bottom center !important;
    transition: transform 0.4s ease !important;
  }

  /* Absolute position and custom scaling to match visual sizes */
  .device-1 {
    left: 6% !important;
    z-index: 10 !important;
    transform: rotate(-10deg) translateY(15px) scale(0.92) !important;
  }
  .device-2 {
    left: 28% !important;
    z-index: 20 !important;
    transform: rotate(-3deg) translateY(-10px) scale(1.06) !important;
  }
  .device-3 {
    left: 50% !important;
    z-index: 30 !important;
    transform: rotate(4deg) translateY(5px) scale(0.98) !important;
  }
  .device-4 {
    left: 72% !important;
    z-index: 40 !important;
    transform: rotate(10deg) translateY(20px) scale(1.02) !important;
  }

  .hero-mobile-device {
    display: none !important;
  }

  @media (max-width: 768px) {
    .hero-container {
      padding-top: 110px !important;
    }
    .hero-devices-row {
      display: block !important;
      position: relative !important;
      width: 100% !important;
      height: 480px !important;
      margin-top: 0.5rem !important;
      overflow: visible !important;
    }
    .hero-mobile-device {
      display: block !important;
      position: absolute !important;
      bottom: 10px !important;
      width: 40% !important;
      height: clamp(410px, 56vh, 510px) !important;
      object-fit: contain !important;
      filter: drop-shadow(0 15px 30px rgba(0, 0, 0, 0.5)) !important;
      transform-origin: bottom center !important;
      transition: transform 0.4s ease !important;
    }
    .mdevice-1 {
      left: 5% !important;
      z-index: 10 !important;
      transform: rotate(-12deg) translateY(12px) scale(0.92) !important;
    }
    .mdevice-2 {
      left: 23% !important;
      z-index: 20 !important;
      transform: rotate(-4deg) translateY(-8px) scale(1.06) !important;
    }
    .mdevice-3 {
      left: 41% !important;
      z-index: 30 !important;
      transform: rotate(4deg) translateY(4px) scale(0.98) !important;
    }
    .mdevice-4 {
      left: 59% !important;
      z-index: 40 !important;
      transform: rotate(12deg) translateY(16px) scale(1.02) !important;
    }
  }
</style>
