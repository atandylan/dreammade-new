---
const productGroups = [
  {
    id: "syokpod-v2",
    name: "SyokPod V2",
    badge: "Closed System",
    toneClass: "tone-dark",
    description: "Built for smooth sessions, standout colourways, and the SyokGeng way of life.",
    href: "/products/syokpod-v2",
    variants: [
      { colorName: "Black",  image: "/products/syokpod/v2/syokpod-v2-black-01.webp" },
      { colorName: "Blue",   image: "/products/syokpod/v2/syokpod-v2-blue-01.webp" },
      { colorName: "Green",  image: "/products/syokpod/v2/syokpod-v2-green-01.webp" },
      { colorName: "Grey",   image: "/products/syokpod/v2/syokpod-v2-grey-01.webp" },
      { colorName: "Red",    image: "/products/syokpod/v2/syokpod-v2-red-01.webp" }
    ]
  },
  {
    id: "syokpod-pro",
    name: "SyokPod Pro",
    badge: "Closed System",
    toneClass: "tone-crimson",
    description: "More grip, more control and a stronger silhouette.",
    href: "/products/syokpod-pro",
    variants: [
      { colorName: "Gold",      image: "/products/syokpod/pro/syokpod-pro-gold-01.webp" },
      { colorName: "Gray",      image: "/products/syokpod/pro/syokpod-pro-gray-01.webp" },
      { colorName: "Green",     image: "/products/syokpod/pro/syokpod-pro-green-01.webp" },
      { colorName: "Light Grey",image: "/products/syokpod/pro/syokpod-pro-lightgrey-01.webp" },
      { colorName: "Obsidian",  image: "/products/syokpod/pro/syokpod-pro-obsidian-01.webp" }
    ]
  },
  {
    id: "syokbar",
    name: "SyokBar",
    badge: "Disposable",
    toneClass: "tone-charcoal",
    description: "Designed around the ease of a disposable format while delivering bold flavours.",
    href: "/products/syokbar",
    variants: [
      { colorName: "Blue",   image: "/products/syokbar/SYOKBAR/syokbar-blue-01.webp" },
      { colorName: "Green",  image: "/products/syokbar/SYOKBAR/syokbar-green-01.webp" },
      { colorName: "Grey",   image: "/products/syokbar/SYOKBAR/syokbar-grey-01.webp" },
      { colorName: "Orange", image: "/products/syokbar/SYOKBAR/syokbar-orange-01.webp" },
      { colorName: "Red",    image: "/products/syokbar/SYOKBAR/syokbar-red-01.webp" }
    ]
  },
  {
    id: "syokbar-target",
    name: "SyokBar Target",
    badge: "Open System",
    toneClass: "tone-deep-red",
    description: "Open-system flexibility with bold flavour control.",
    href: "/products/syokbar-target",
    variants: [
      { colorName: "Green",  image: "/products/syokbar/SYOKBAR TARGET/syokbar-target-green-01.webp" },
      { colorName: "Orange", image: "/products/syokbar/SYOKBAR TARGET/syokbar-target-orange-01.webp" },
      { colorName: "Red",    image: "/products/syokbar/SYOKBAR TARGET/syokbar-target-red-01.webp" }
    ]
  }
];
---

<section class="product-stacking-section" id="products">
  <div class="product-stacking-header wrap">
    <div class="eyebrow">The Lineup</div>
    <h2>REFUSE TO BE ORDINARY.</h2>
  </div>

  {productGroups.map((group, idx) => (
    <div
      class="product-stack-card"
      id={`pcard-${idx}`}
      style={`top: ${18 + idx * 6}vh`}
    >
      <div class={`product-stack-inner ${group.toneClass}`}>

        <div class="pstack-content pstack-info">
          <span class="pstack-badge">{group.badge ?? group.name}</span>
          <h3 class="pstack-name">{group.name}</h3>
          <p class="pstack-colors">Available in {group.variants.length} colours</p>
          <p class="pstack-desc">{group.description}</p>
          <a href={group.href} class="pstack-cta">Explore →</a>
        </div>

        <div class="pstack-images">
          {group.variants.map((variant, vIdx) => {
            let rightPercent = vIdx * 18 + 6; 
            let imgHeight = 96; // Default height

            if (group.id === "syokpod-v2") {
              rightPercent = vIdx * 13 + 12; // Shifted left to fit cleanly inside card padding
            } else if (group.id === "syokbar-target") {
              rightPercent = vIdx * 25 + 6; // 3 devices
            } else if (group.id === "syokbar") {
              rightPercent = vIdx * 16 + 6; // Slightly tighter packing to shift left device away from text
              imgHeight = 93.5; // Slightly scaled down by ~2px to 3px
            }

            const numVariants = group.variants.length;
            const midIdx = (numVariants - 1) / 2;
            const rotVal = (midIdx - vIdx) * (numVariants === 3 ? 5 : 3.5);
            const yVal = Math.abs(midIdx - vIdx) * 3;

            return (
              <img
                src={variant.image}
                alt={variant.colorName}
                class="pstack-img"
                style={`
                  position: absolute;
                  bottom: 1.5rem;
                  right: ${rightPercent}%;
                  height: ${imgHeight}%; /* Sized to fit cleanly inside the card container */
                  z-index: ${(vIdx + 1) * 10}; /* Correct z-index stacking */
                  opacity: ${1 - vIdx * 0.08};
                  filter: drop-shadow(0 -10px 20px rgba(0,0,0,0.4));
                  transform: rotate(${rotVal}deg) translateY(${yVal}px);
                  --vIdx: ${vIdx};
                `}
                loading="lazy"
                decoding="async"
              />
            );
          })}
        </div>

      </div>
    </div>
  ))}
</section>

<style>
@keyframes fanFloat {
  from { transform: translateY(0px); }
  to   { transform: translateY(-12px); }
}

.pstack-images {
  position: absolute;
  right: 0 !important;
  left: auto;
  bottom: 0;
  width: 50% !important;
  height: 100%;
  pointer-events: none;
  overflow: visible;
}

.pstack-img {
  position: absolute;
  bottom: 0;
  max-width: none;
  object-fit: contain;
  filter: drop-shadow(0 16px 32px rgba(0,0,0,0.5));
  transform-origin: bottom center;
}

.product-stack-inner {
  padding: 1.5rem !important; /* Reduced card padding (similar to p-6) */
  overflow: visible !important;
}

.product-stack-card {
  overflow: visible !important;
}

.pstack-info {
  width: 40% !important;
  max-width: none !important;
}

.pstack-name {
  font-size: clamp(38px, 4.5vw, 58px) !important; /* Enlarged title (text-5xl/6xl equivalent) */
  line-height: 1.0 !important;
  margin: 12px 0 6px !important;
  text-transform: uppercase !important;
}

.pstack-desc {
  font-size: clamp(15px, 1.1vw, 18px) !important; /* Enlarged description font size */
  max-width: 42ch !important;
}

@media (max-width: 760px) {
  .product-stack-inner {
    padding: 1.5rem !important; /* Dense padding on mobile */
  }
  .pstack-info {
    width: 100% !important;
  }
  .pstack-images {
    position: relative !important;
    left: 0 !important;
    right: 0 !important;
    width: 100% !important;
    height: 120% !important;
  }
  .pstack-img {
    right: calc(var(--vIdx) * 6%) !important; /* Extremely tight spread for narrow mobile screens */
    left: auto !important;
  }
}

/* ── Tone variants ── */
.tone-dark {
  background: linear-gradient(135deg, #1a1a1a, #0d0d0d);
  color: var(--text-light, #f7f3ee);
}
.tone-crimson {
  background: linear-gradient(135deg, #1e0204, #2d0307);
  color: var(--text-light, #f7f3ee);
}
.tone-charcoal {
  background: linear-gradient(135deg, #111111, #1a1a1a);
  color: var(--text-light, #f7f3ee);
}
.tone-deep-red {
  background: linear-gradient(135deg, #1a0303, #250404);
  color: var(--text-light, #f7f3ee);
}

/* ── Section header ── */
.product-stacking-section .eyebrow {
  color: var(--brand-red, #91050b);
  position: relative;
  z-index: 30;
}
.product-stacking-section h2 {
  font-size: clamp(28px, 4vw, 52px);
  line-height: 0.95;
  margin: 8px 0 0;
  text-transform: uppercase;
  color: var(--text-light, #f7f3ee);
  position: relative;
  z-index: 30;
}

.product-stacking-section {
  padding-bottom: clamp(100px, 15vh, 200px) !important;
}
</style>
