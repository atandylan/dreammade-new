---
const products = [
  {
    id: "syokpod-v2",
    name: "SyokPod V2",
    desc: "A closed-system device built for smooth sessions, standout colourways, and the SyokGeng way of life.",
    compat: "Closed system / KOHS K1000",
    images: [
      { src: "/products/syokpod/v2/syokpod-v2-black-01.webp", alt: "SyokPod V2 Black" },
      { src: "/products/syokpod/v2/syokpod-v2-blue-01.webp", alt: "SyokPod V2 Blue" },
      { src: "/products/syokpod/v2/syokpod-v2-green-01.webp", alt: "SyokPod V2 Green" },
      { src: "/products/syokpod/v2/syokpod-v2-grey-01.webp", alt: "SyokPod V2 Grey" },
      { src: "/products/syokpod/v2/syokpod-v2-red-01.webp", alt: "SyokPod V2 Red" }
    ]
  },
  {
    id: "syokpod-pro",
    name: "SyokPod Pro",
    desc: "More grip, more control and a stronger silhouette.",
    compat: "Closed system / KOHS K1000",
    images: [
      { src: "/products/syokpod/pro/syokpod-pro-gold-01.webp", alt: "SyokPod Pro Gold" },
      { src: "/products/syokpod/pro/syokpod-pro-gray-01.webp", alt: "SyokPod Pro Gray" },
      { src: "/products/syokpod/pro/syokpod-pro-green-01.webp", alt: "SyokPod Pro Green" },
      { src: "/products/syokpod/pro/syokpod-pro-lightgrey-01.webp", alt: "SyokPod Pro Lightgrey" },
      { src: "/products/syokpod/pro/syokpod-pro-obsidian-01.webp", alt: "SyokPod Pro Obsidian" }
    ]
  },
  {
    id: "syokbar",
    name: "SyokBar",
    desc: "Designed around the ease of a disposable format while delivering bold flavours.",
    compat: "Disposable system / KOHS K3000",
    images: [
      { src: "/products/syokbar/SYOKBAR/syokbar-blue-01.webp", alt: "SyokBar Blue" },
      { src: "/products/syokbar/SYOKBAR/syokbar-green-01.webp", alt: "SyokBar Green" },
      { src: "/products/syokbar/SYOKBAR/syokbar-grey-01.webp", alt: "SyokBar Grey" },
      { src: "/products/syokbar/SYOKBAR/syokbar-orange-01.webp", alt: "SyokBar Orange" },
      { src: "/products/syokbar/SYOKBAR/syokbar-red-01.webp", alt: "SyokBar Red" }
    ]
  },
  {
    id: "syokbar-target",
    name: "SyokBar Target",
    desc: "Open-system flexibility with bold flavour control.",
    compat: "Open system / KOHS E-Liquid",
    images: [
      { src: "/products/syokbar/SYOKBAR TARGET/syokbar-target-green-01.webp", alt: "SyokBar Target Green" },
      { src: "/products/syokbar/SYOKBAR TARGET/syokbar-target-orange-01.webp", alt: "SyokBar Target Orange" },
      { src: "/products/syokbar/SYOKBAR TARGET/syokbar-target-red-01.webp", alt: "SyokBar Target Red" }
    ]
  }
];
---

<section class="product-showcase" id="products" aria-label="The Syok System">
  <div class="wrap">
    <div class="product-showcase-header">
      <div class="eyebrow" data-reveal>Product Highlight</div>
      <h2 data-reveal>Four ways to Syok.</h2>
    </div>
    
    <div class="product-list">
      {products.map((p, idx) => (
        <div class="product-row" data-reveal>
          <div class="product-name-group">
            <span class="eyebrow">0{idx + 1}</span>
            <h3>{p.name}</h3>
          </div>
          <div class="swatch-row">
            {p.images.map((img) => {
              const colorName = img.alt.split(' ').pop();
              return (
                <img 
                  src={img.src} 
                  alt={colorName} 
                  class="swatch-img" 
                  loading="lazy" 
                  decoding="async" 
                />
              );
            })}
          </div>
          <a href={`/products/${p.id}`} class="product-row-link">Explore →</a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.product-showcase { background: var(--brand-cream-light); color: var(--brand-ink); padding: clamp(32px, 5vw, 64px) 0; }
.product-showcase-header { margin-bottom: 32px; }
.product-showcase-header h2 { font-size: clamp(28px, 4vw, 52px); line-height: .95; margin: 8px 0 0; text-transform: uppercase; }
.product-list { display: flex; flex-direction: column; width: 100%; }
.product-row { display: grid; grid-template-columns: minmax(0,1.4fr) minmax(0,2fr) auto; align-items: center; gap: clamp(12px, 2vw, 32px); padding: clamp(14px, 2vw, 22px) 0; border-bottom: 1px solid rgba(9,9,9,.08); transition: background .25s ease; cursor: default; }
.product-row:first-child { border-top: 1px solid rgba(9,9,9,.08); }
.product-row:hover { background: rgba(145,5,11,.03); }
.product-name-group { display: flex; align-items: baseline; gap: 12px; min-width: 0; }
.product-name-group .eyebrow { flex-shrink: 0; color: var(--brand-red); font-size: 10px; font-weight: 800; letter-spacing: .1em; }
.product-name-group h3 { font-family: var(--font-display); font-size: clamp(16px, 2vw, 22px); margin: 0; line-height: 1; text-transform: uppercase; color: var(--brand-ink); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.swatch-row { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }
.swatch-img { width: 44px; height: 44px; object-fit: contain; border-radius: 6px; background: rgba(9,9,9,.04); flex-shrink: 0; transition: transform .25s ease; }
.product-row:hover .swatch-img { transform: scale(1.08); }
.product-row-link { font-family: var(--font-body); font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: .1em; color: rgba(9,9,9,.45); white-space: nowrap; transition: color .25s ease; flex-shrink: 0; }
.product-row:hover .product-row-link { color: var(--brand-red); }

@media (max-width: 760px) {
  .product-row { grid-template-columns: 1fr auto; grid-template-rows: auto auto; gap: 10px 12px; }
  .product-name-group { grid-column: 1; }
  .swatch-row { grid-column: 1 / -1; }
  .product-row-link { grid-column: 2; grid-row: 1; }
}
@media (max-width: 480px) {
  .swatch-img { width: 36px; height: 36px; }
}
</style>
