---
const products = [
  {
    id: "syokpod-v2",
    name: "SyokPod V2",
    desc: "A closed-system device built for smooth sessions, standout colourways, and the SyokGeng way of life.",
    compat: "Closed system / KOHS K1000",
    images: [
      { src: "/products/syokpod/v2/syokpod-v2-black-01.webp", alt: "SyokPod V2 Black" },
      { src: "/products/syokpod/v2/syokpod-v2-blue-01.webp", alt: "SyokPod V2 Blue" },
      { src: "/products/syokpod/v2/syokpod-v2-green-01.webp", alt: "SyokPod V2 Green" },
      { src: "/products/syokpod/v2/syokpod-v2-grey-01.webp", alt: "SyokPod V2 Grey" },
      { src: "/products/syokpod/v2/syokpod-v2-red-01.webp", alt: "SyokPod V2 Red" }
    ]
  },
  {
    id: "syokpod-pro",
    name: "SyokPod Pro",
    desc: "More grip, more control and a stronger silhouette.",
    compat: "Closed system / KOHS K1000",
    images: [
      { src: "/products/syokpod/pro/syokpod-pro-gold-01.webp", alt: "SyokPod Pro Gold" },
      { src: "/products/syokpod/pro/syokpod-pro-gray-01.webp", alt: "SyokPod Pro Gray" },
      { src: "/products/syokpod/pro/syokpod-pro-green-01.webp", alt: "SyokPod Pro Green" },
      { src: "/products/syokpod/pro/syokpod-pro-lightgrey-01.webp", alt: "SyokPod Pro Lightgrey" },
      { src: "/products/syokpod/pro/syokpod-pro-obsidian-01.webp", alt: "SyokPod Pro Obsidian" }
    ]
  },
  {
    id: "syokbar",
    name: "SyokBar",
    desc: "Designed around the ease of a disposable format while delivering bold flavours.",
    compat: "Disposable system / KOHS K3000",
    images: [
      { src: "/products/syokbar/SYOKBAR/syokbar-blue-01.webp", alt: "SyokBar Blue" },
      { src: "/products/syokbar/SYOKBAR/syokbar-green-01.webp", alt: "SyokBar Green" },
      { src: "/products/syokbar/SYOKBAR/syokbar-grey-01.webp", alt: "SyokBar Grey" },
      { src: "/products/syokbar/SYOKBAR/syokbar-orange-01.webp", alt: "SyokBar Orange" },
      { src: "/products/syokbar/SYOKBAR/syokbar-red-01.webp", alt: "SyokBar Red" }
    ]
  },
  {
    id: "syokbar-target",
    name: "SyokBar Target",
    desc: "Open-system flexibility with bold flavour control.",
    compat: "Open system / KOHS E-Liquid",
    images: [
      { src: "/products/syokbar/SYOKBAR TARGET/syokbar-target-green-01.webp", alt: "SyokBar Target Green" },
      { src: "/products/syokbar/SYOKBAR TARGET/syokbar-target-orange-01.webp", alt: "SyokBar Target Orange" },
      { src: "/products/syokbar/SYOKBAR TARGET/syokbar-target-red-01.webp", alt: "SyokBar Target Red" }
    ]
  }
];
---

<section class="product-showcase" id="products" aria-label="The Syok System">
  <div class="wrap">
    <div class="product-showcase-header">
      <div class="eyebrow" data-reveal>Product Highlight</div>
      <h2 data-reveal>Four ways to Syok.</h2>
    </div>
    
    <div class="product-frames-grid">
      {products.map((p, idx) => (
        <div class="product-frame" data-reveal>
          <div class="product-frame-header">
            <span class="eyebrow">0{idx + 1}</span>
            <h3>{p.name}</h3>
          </div>
          <div class="product-colors">
            {p.images.map((img) => {
              const colorName = img.alt.split(' ').pop();
              return (
                <img 
                  src={img.src} 
                  alt={colorName} 
                  class="product-color-img"
                  loading="lazy" 
                  decoding="async" 
                />
              );
            })}
          </div>
          <a href={`/products/${p.id}`} class="product-frame-link">Explore →</a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.product-showcase {
  background: var(--brand-cream-light);
  color: var(--brand-ink);
  padding: clamp(40px, 6vw, 80px) 0;
}
.product-showcase-header {
  margin-bottom: var(--space-4, 16px);
}
.product-showcase-header h2 {
  font-size: clamp(32px, 5vw, 64px);
  line-height: .95;
  margin: 12px 0 0;
  text-transform: uppercase;
}
.product-frames-grid { 
  display: grid; 
  grid-template-columns: repeat(4, 1fr); 
  gap: var(--space-4, 16px); 
  padding: var(--space-8, 64px) var(--space-6, 24px); 
}
.product-frame { 
  background: var(--color-surface, #ffffff); 
  border-radius: var(--radius-lg, 16px); 
  padding: var(--space-6, 24px); 
  display: flex; 
  flex-direction: column; 
  gap: var(--space-4, 16px); 
  border: 1px solid rgba(9, 9, 9, 0.04);
  box-shadow: 0 8px 24px rgba(9, 9, 9, 0.02);
  transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease;
}
.product-frame:hover {
  transform: translateY(-4px);
  box-shadow: 0 16px 36px rgba(9, 9, 9, 0.06);
}
.product-frame-header {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.product-frame-header .eyebrow {
  color: var(--brand-red);
  font-family: var(--font-body);
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 0.1em;
}
.product-frame-header h3 {
  font-family: var(--font-display);
  font-size: clamp(20px, 2.5vw, 28px);
  margin: 0;
  line-height: 1;
  text-transform: uppercase;
  color: var(--brand-ink);
}
.product-colors { 
  display: flex; 
  flex-wrap: wrap; 
  gap: var(--space-2, 8px); 
  align-items: flex-end; 
  margin-top: auto;
  min-height: 120px;
}
.product-color-img { 
  width: clamp(60px, 7vw, 100px); 
  height: auto; 
  object-fit: contain; 
  filter: drop-shadow(0 6px 12px rgba(0, 0, 0, 0.06));
  transition: transform 0.3s ease;
}
.product-frame:hover .product-color-img {
  transform: scale(1.05);
}
.product-frame-link {
  font-family: var(--font-display);
  font-size: 13px;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--brand-ink);
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  transition: color 0.3s ease;
  margin-top: var(--space-4, 16px);
}
.product-frame-link:hover {
  color: var(--brand-red);
}

@media (max-width: 900px) { 
  .product-frames-grid { grid-template-columns: repeat(2, 1fr); } 
}
@media (max-width: 560px) { 
  .product-frames-grid { grid-template-columns: 1fr; } 
}
</style>
