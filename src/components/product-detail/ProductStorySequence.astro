---
import type { ProductExperience } from "../../data/productExperience";

type Props = { experience: ProductExperience };
const { experience } = Astro.props;
const slides = (experience.storySlides ?? []).slice(0, 3);
---

{slides.length > 0 && (
  <section class="product-story-sequence" aria-label={`${experience.name} product story`}>
    {slides.map((slide, index) => (
      <article class:list={["product-story-slide", `product-story-${slide.tone ?? "cream"}`, { "product-story-reverse": index % 2 === 1 }]} data-product-story-slide>
        <div class="product-story-media">
          <img src={slide.image} alt={slide.imageAlt} loading={index === 0 ? "eager" : "lazy"} decoding="async" />
        </div>
        <div class="product-story-copy">
          <span class="eyebrow">{slide.eyebrow}</span>
          <h2>{slide.title}</h2>
          <p>{slide.body}</p>
        </div>
      </article>
    ))}
  </section>
)}
