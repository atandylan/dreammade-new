---
import ProductFamilyMark from "../shared/ProductFamilyMark.astro";

const standard = [
  "/products/syokbar/SYOKBAR/syokbar-red-01.webp",
  "/products/syokbar/SYOKBAR/syokbar-green-01.webp",
  "/products/syokbar/SYOKBAR/syokbar-blue-01.webp",
  "/products/syokbar/SYOKBAR/syokbar-orange-01.webp",
  "/products/syokbar/SYOKBAR/syokbar-grey-01.webp"
];
const target = [
  "/products/syokbar/SYOKBAR TARGET/syokbar-target-orange-01.webp",
  "/products/syokbar/SYOKBAR TARGET/syokbar-target-green-01.webp",
  "/products/syokbar/SYOKBAR TARGET/syokbar-target-red-01.webp"
];
---

<section class="syokbar-campaign-system" id="disposable-system" aria-label="SyokBar product campaigns">
  <article class="syokbar-campaign syokbar-campaign-standard" id="syokbar" data-syokbar-campaign data-product-story-slide>
    <div class="syokbar-copy">
      <div class="product-family-signature">
        <ProductFamilyMark family="syokbar" />
        <span class="eyebrow">Disposable System / Syok Series</span>
      </div>
      <h2 class="whitespace-nowrap">SYOKBAR</h2>
      <h3>Made to move. Built to stand out.</h3>
      <p>Five bold colours, a compact screen, and disposable convenience shaped for the Syok lifestyle.</p>
      <a class="campaign-link" href="/products/syokbar">Explore SyokBar</a>
    </div>
    <div class="syokbar-lineup" data-syokbar-lineup>
      {standard.map((image, index) => (
        <span class={`syokbar-device syokbar-device-${index + 1}`}>
          <img src={image} alt={`SyokBar colour face ${index + 1}`} loading={index < 2 ? "eager" : "lazy"} />
        </span>
      ))}
    </div>
  </article>

  <div class="syokbar-special-grid" id="syokbar-special-editions">
    <a class="syokbar-special-panel syokbar-fifa-panel" href="/products/syokbar-special-editions?variant=fifa&finish=england&view=1" data-syokbar-poster data-product-story-slide>
      <img class="syokbar-special-bg" src="/products/syokbar/SYOKBAR FIFA/all-syokbar-fifa.jpg" alt="SyokBar FIFA campaign lineup" loading="lazy" decoding="async" />
      <span class="syokbar-special-copy">
        <small>Collector edition</small>
        <b class="whitespace-nowrap">SYOKBAR FIFA</b>
        <span>Four countries. One match-day energy.</span>
        <em>Explore edition</em>
      </span>
    </a>
    <a class="syokbar-special-panel syokbar-camo-panel" href="/products/syokbar-special-editions?variant=camo&view=1" data-syokbar-poster data-product-story-slide>
      <img class="syokbar-special-bg" src="/products/syokbar/SYOKBAR CAMO EDITION/camo-shoot-3.jpg" alt="SyokBar Camo outdoor campaign" loading="lazy" decoding="async" />
      <span class="syokbar-special-copy">
        <small>Utility edition</small>
        <b class="whitespace-nowrap">CAMO EDITION</b>
        <span>Field tone. Street energy.</span>
        <em>Explore edition</em>
      </span>
    </a>
  </div>

  <div id="open-system"></div>
  <article class="syokbar-campaign syokbar-target-campaign" id="syokbar-target" data-syokbar-campaign data-product-story-slide>
    <div class="syokbar-copy">
      <div class="product-family-signature">
        <ProductFamilyMark family="syokbar" />
        <span class="eyebrow">Open System / Syok Series</span>
      </div>
      <h2 class="whitespace-nowrap">SYOKBAR TARGET</h2>
      <h3>Refill. Switch. Stay in rhythm.</h3>
      <p>A compact open-system device with bold colour, an LCD screen, and control built for everyday movement.</p>
      <a class="campaign-link" href="/products/syokbar-target">Explore SyokBar Target</a>
    </div>
    <div class="syokbar-target-stage" data-syokbar-lineup>
      {target.map((image, index) => (
        <span class={`syokbar-target-device syokbar-target-device-${index + 1}`}>
          <img src={image} alt={`SyokBar Target device ${index + 1}`} loading="lazy" />
        </span>
      ))}
    </div>
  </article>
</section>
