---
import { site } from "../../data/site";

type Props = {
  variant?: "standard" | "reveal";
};

const { variant = "standard" } = Astro.props;
---

{variant === "reveal" ? (
  <section class="footer-reveal" id="contact">
    <footer class="wrap footer-content">
      <div class="footer-word">{site.name}</div>
      
      <div class="footer-reveal-grid">
        <div class="footer-reveal-col">
          <span class="footer-kicker">Sitemap</span>
          <nav>
            <a href="/">Home</a>
            <a href="/about">About</a>
            <a href="/products">Products</a>
            <a href="/events">Events</a>
            <a href="/clothing">Clothing</a>
            <a href="/contact">Contact</a>
          </nav>
        </div>

        <div class="footer-reveal-col">
          <span class="footer-kicker">Product System</span>
          <nav>
            <a href="/products#closed-system">Closed System</a>
            <a href="/products#disposable-system">Disposable System</a>
            <a href="/products#open-system">Open System</a>
          </nav>
        </div>

        <div class="footer-reveal-col">
          <span class="footer-kicker">Contact</span>
          <nav>
            <a href={`mailto:${site.contactEmail}`}>{site.contactEmail}</a>
            <a href="/contact">Contact Dreammade</a>
          </nav>
        </div>
      </div>

      <div class="footer-bottom">
        <div class="footer-copyright">
          <span>&copy; 2026 {site.name}.</span>
          <span>Owned by {site.companyOwner}.</span>
        </div>
        <div class="footer-adult-note">
          <span>Adult-only product culture site.</span>
          <span>Follow legal age rules in your location.</span>
        </div>
        <div class="footer-credit">
          <a href={site.credit.href} target="_blank" rel="noopener noreferrer">{site.credit.label}</a>
        </div>
      </div>
    </footer>
  </section>
) : (
  <footer class="footer footer-standard" id="contact">
    <div class="wrap footer-grid">
      <div class="footer-top">
        <div class="footer-word">{site.name}</div>
      </div>

      <div class="footer-columns">
        <div class="footer-column">
          <h3>Sitemap</h3>
          <nav>
            <a href="/">Home</a>
            <a href="/about">About Us</a>
            <a href="/products">Products</a>
            <a href="/events">Events</a>
            <a href="/clothing">Clothing</a>
            <a href="/contact">Contact Us</a>
          </nav>
        </div>

        <div class="footer-column">
          <h3>Product System</h3>
          <nav>
            <a href="/products#closed-system">Closed System</a>
            <a href="/products#disposable-system">Disposable System</a>
            <a href="/products#open-system">Open System</a>
          </nav>
        </div>

        <div class="footer-column">
          <h3>Contact</h3>
          <nav>
            <span>Email:</span>
            <a href={`mailto:${site.contactEmail}`}>{site.contactEmail}</a>
            <span class="mt">Inquiries:</span>
            <span>Product / Collaboration / Events / SyokGeng</span>
          </nav>
        </div>

        <div class="footer-column">
          <h3>Social</h3>
          <nav class="footer-social-nav">
            {site.socials.map((social) => (
              <a
                class="footer-social-link"
                href={social.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Follow SyokGeng on ${social.label}`}
              >
                <span class="footer-social-icon" aria-hidden="true">
                  {social.platform === "instagram" ? (
                    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" aria-hidden="true" focusable="false">
                      <rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.8" />
                      <circle cx="12" cy="12" r="4.2" stroke="currentColor" stroke-width="1.8" />
                      <circle cx="17.2" cy="6.8" r="1.1" fill="currentColor" />
                    </svg>
                  ) : (
                    <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true" focusable="false">
                      <path d="M14.4 3c.5 3.1 2.2 5 5 5.2v3.3a8.2 8.2 0 0 1-5-1.6v5.8c0 3.4-2.3 5.8-5.6 5.8A5.4 5.4 0 0 1 3.3 16c0-3.4 2.8-5.8 6.2-5.4v3.5c-1.5-.4-2.8.5-2.8 1.9 0 1.2.9 2.1 2.1 2.1 1.4 0 2.2-.9 2.2-2.6V3h3.4Z" />
                    </svg>
                  )}
                </span>
                <span class="footer-social-copy">
                  <strong>{social.label}</strong>
                  <small>{social.handle}</small>
                </span>
              </a>
            ))}
          </nav>
        </div>
      </div>

      <div class="footer-bottom">
        <div class="footer-copyright">
          <span>&copy; 2026 {site.name}.</span>
          <span>Owned by {site.companyOwner}.</span>
        </div>
        <div class="footer-adult-note">
          <span>Adult-only product culture site.</span>
          <span>Follow legal age rules in your location.</span>
        </div>
        <div class="footer-credit">
          <a href={site.credit.href} target="_blank" rel="noopener noreferrer">{site.credit.label}</a>
        </div>
      </div>
    </div>
  </footer>
)}
