---
import Navbar from "../components/global/Navbar.astro";
import Footer from "../components/global/Footer.astro";
import HorizontalMediaRail from "../components/shared/HorizontalMediaRail.astro";
import { clothingAccessoriesData, clothingData } from "../data/clothing";

import "../styles/global.css";
import "../styles/components.css";
import "../styles/motion.css";
import "../styles/horizontal-media-rail.css";
import "../styles/clothing.css";

interface ReelItem {
  id: string;
  caption?: string;
  media_type?: string;
  media_url?: string;
  permalink?: string;
  thumbnail_url?: string;
}

let reelsData: ReelItem[] = [];
try {
  const response = await fetch("https://dreammade-ig-reels.fadzry-work.workers.dev/");
  if (response.ok) {
    const json = await response.json();
    const all: ReelItem[] = Array.isArray(json.reels) ? json.reels
      : Array.isArray(json.photos) ? json.photos : [];
    // Videos + thumbnails only
    reelsData = all.filter(
      (item) => item.media_type === "VIDEO" || item.media_url?.includes(".mp4") || item.thumbnail_url
    );
  }
} catch (e) {
  console.error("Failed to fetch reels for clothing:", e);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Dreammade - SyokGeng Clothing</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Inter:wght@400..900&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Navbar variant="standard" activeLabel="Clothing" />
    <main>
      <section class="clothing-hero page-hero dream-texture-red">
        <div class="wrap">
          <div class="clothing-hero-copy">
            <div class="eyebrow reveal">SYOKGENG / DREAMMADE</div>
            <div class="clothing-brand reveal">SYOKGENG</div>
            <h1 class="reveal">NOT JUST WORN. CARRIED.</h1>
          </div>
        </div>
      </section>

      <div class="clothing-lookbook" aria-label="SyokGeng Lookbook">
        {clothingData.map((group, groupIndex) => {
          const toneClass = groupIndex % 2 === 0
            ? "lookbook-group-cream surface-cream-clean"
            : "lookbook-group-red surface-red-grain";
          return (
            <section class:list={["lookbook-group", toneClass]}>
              <div class="wrap lookbook-header">
                <h2 class="lookbook-title" data-clothing-title>{group.name}</h2>
              </div>
              <div class="wrap lookbook-grid-container">
                <div class="lookbook-grid" id={`clothing-${group.id}`}>
                  {group.images.map((image, index) => (
                    <div class="lookbook-item">
                      <div class="lookbook-image-wrapper">
                        <img
                          src={image}
                          alt={`${group.name} look ${index + 1}`}
                          loading={groupIndex === 0 && index < 2 ? "eager" : "lazy"}
                          decoding="async"
                        />
                        <div class="lookbook-image-overlay"></div>
                        <div class="lookbook-item-badge">SyokGeng</div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
              <div class="wrap lookbook-actions">
                <button class="lookbook-see-more-btn" data-target={`modal-${group.id}`}>See All Photos</button>
              </div>

              <div class="lookbook-modal" id={`modal-${group.id}`} role="dialog" aria-modal="true">
                <button class="modal-close" aria-label="Close">✕</button>
                <div class="modal-grid">
                  {group.images.map((image, index) => (
                    <img
                      src={image}
                      alt={`${group.name} look ${index + 1}`}
                      loading="lazy"
                      decoding="async"
                    />
                  ))}
                </div>
              </div>
            </section>
          );
        })}
      </div>

      <section class="accessories-section">
        <div class="wrap">
          <header class="accessories-header">
            <div class="eyebrow">Accessories</div>
            <h2>SMALL OBJECTS. SAME SIGNAL.</h2>
            <p>The SyokGeng identity continues beyond clothing through clean, everyday pieces.</p>
          </header>

          <div class="accessories-catalogue">
            <article class="accessory-casing-card">
              <img src={clothingAccessoriesData.casing.image} alt="SyokGeng Casing" loading="lazy" decoding="async" />
              <div class="accessory-labels">
                <span class="label-large">CASING</span>
                <span class="label-small">SYOKGENG ACCESSORY</span>
              </div>
            </article>

            <div class="accessory-eyewear">
              <div class="eyebrow">SYOKGENG EYEWEAR</div>
              <h3>SUNGLASS</h3>
              <HorizontalMediaRail
                id="accessories-sunglass"
                images={clothingAccessoriesData.eyewear.images}
                altPrefix="SyokGeng Sunglass look"
                initialCount={6}
                eagerCount={0}
                className="accessories-eyewear-gallery"
              />
            </div>
          </div>
        </div>
      </section>

      <section class="clothing-reels dream-texture-cream" id="clothing-reels">
        <div class="wrap">
          <div class="eyebrow">Follow SyokGeng</div>
          <h2 class="clothing-reels-title">SEE THE GENG IN MOTION.</h2>
        </div>
        <div class="clothing-reels-track-container">
          <div class="clothing-reels-track" id="clothingReelsTrack" aria-label="SyokGeng reels">
            {reelsData.map((reel) => (
              <article class="clothing-reel-card">
                <a href={reel.permalink || "https://www.instagram.com/syok_geng/"} target="_blank" rel="noopener noreferrer" class="clothing-reel-link" aria-label={reel.caption || "SyokGeng reel"}>
                  <div class="clothing-reel-media">
                    <img
                      src={reel.thumbnail_url || reel.media_url}
                      alt={reel.caption?.split('\n')[0] || "SyokGeng"}
                      loading="lazy"
                      decoding="async"
                    />
                    <div class="clothing-reel-play-icon">▶</div>
                  </div>
                </a>
              </article>
            ))}
            {/* Duplicate for infinite scroll */}
            {reelsData.map((reel) => (
              <article class="clothing-reel-card" aria-hidden="true">
                <a href={reel.permalink || "https://www.instagram.com/syok_geng/"} target="_blank" rel="noopener noreferrer" class="clothing-reel-link" tabindex="-1">
                  <div class="clothing-reel-media">
                    <img
                      src={reel.thumbnail_url || reel.media_url}
                      alt={reel.caption?.split('\n')[0] || "SyokGeng"}
                      loading="lazy"
                      decoding="async"
                    />
                    <div class="clothing-reel-play-icon">▶</div>
                  </div>
                </a>
              </article>
            ))}
          </div>
        </div>
        <div class="wrap clothing-reels-footer">
          <a href="https://www.instagram.com/syok_geng/" target="_blank" rel="noopener noreferrer" class="clothing-reels-cta">@syok_geng on Instagram →</a>
          <a href="https://www.tiktok.com/@syokgeng" target="_blank" rel="noopener noreferrer" class="clothing-reels-cta">@syokgeng on TikTok →</a>
        </div>
      </section>
    </main>

    <Footer variant="standard" />
    <script>
      import { initClothingMotion } from "../scripts/clothingMotion";
      initClothingMotion();
      document.addEventListener("astro:page-load", initClothingMotion);

      function initLookbookModals() {
        const modals = document.querySelectorAll('.lookbook-modal');
        const seeMoreButtons = document.querySelectorAll('.lookbook-see-more-btn');

        seeMoreButtons.forEach(btn => {
          const newBtn = btn.cloneNode(true) as HTMLButtonElement;
          btn.parentNode?.replaceChild(newBtn, btn);

          newBtn.addEventListener('click', () => {
            const targetId = newBtn.getAttribute('data-target');
            if (targetId) {
              const modal = document.getElementById(targetId);
              if (modal) {
                modal.classList.add('is-open');
                document.body.classList.add('locked');
              }
            }
          });
        });

        modals.forEach(modal => {
          const closeBtn = modal.querySelector('.modal-close');
          const closeModal = () => {
            modal.classList.remove('is-open');
            if (!document.querySelector('.lookbook-modal.is-open')) {
              document.body.classList.remove('locked');
            }
          };

          closeBtn?.addEventListener('click', (e) => {
            e.stopPropagation();
            closeModal();
          });

          modal.addEventListener('click', (e) => {
            if (e.target === modal) {
              closeModal();
            }
          });

          const onKeyDown = (e: KeyboardEvent) => {
            if (e.key === 'Escape' && modal.classList.contains('is-open')) {
              closeModal();
            }
          };
          window.addEventListener('keydown', onKeyDown);

          document.addEventListener('astro:before-swap', () => {
            window.removeEventListener('keydown', onKeyDown);
          }, { once: true });
        });
      }

      initLookbookModals();
      document.addEventListener("astro:page-load", initLookbookModals);
    </script>
  </body>
</html>
